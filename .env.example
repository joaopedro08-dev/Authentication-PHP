APP_ENV=development
APP_URL=http://localhost

# Database Driver: mysql, pgsql, sqlsrv, sqlite
DB_DRIVER=mysql

# MySQL Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=auth_php
DB_USER=root
DB_PASS=

# PostgreSQL Configuration (when DB_DRIVER=pgsql)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=auth_php
# DB_USER=postgres
# DB_PASS=

# SQL Server Configuration (when DB_DRIVER=sqlsrv)
# DB_HOST=127.0.0.1
# DB_PORT=1433
# DB_NAME=auth_php
# DB_USER=sa
# DB_PASS=

# SQLite Configuration (when DB_DRIVER=sqlite)
# DB_FILE=/path/to/database.sqlite

JWT_SECRET=replace_with_a_long_random_secret
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000